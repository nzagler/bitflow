{
  "name": "bitflow",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted qBittorrent throttling automation for Jellyfin and network device activity.",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build && tsup server.ts --format cjs --target node20 --out-dir dist --external next --external better-sqlite3",
    "start": "node dist/server.js",
    "lint": "next lint",
    "db:check": "tsx scripts/db-check.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "next-themes": "^0.4.4",
    "ping": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
